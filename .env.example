# ===========================================
# CONFIGURACIÓN DE ENTORNO - BIENIESTAR
# Copia este archivo como .env y llena los valores
# ===========================================

# --- APLICACIÓN ---
APP_ENV=development
APP_DEBUG=true
BASE_URL=http://localhost/a/Bienestar/public

# --- BASE DE DATOS ---
DB_HOST=localhost
DB_NAME=sistema_usuarios
DB_USER=root
DB_PASS=

# --- GOOGLE OAUTH ---
# Crear credenciales en https://console.cloud.google.com
# Tipo: Aplicación web → Agregar URI de redirección autorizado
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost/a/Bienestar/public/auth/google/callback

# --- EMAIL (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_password_de_aplicacion
MAIL_FROM=noreply@bieniestar.com
MAIL_FROM_NAME=BIENIESTAR

# --- GOOGLE CALENDAR API ---
GOOGLE_CALENDAR_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
GOOGLE_CALENDAR_API_KEY=TU_GOOGLE_CALENDAR_API_KEY
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost/a/Bienestar/public/pages/citas.php

# --- EMAILJS (Para envío de correos de citas) ---
# 1. Crear cuenta en https://www.emailjs.com
# 2. Crear un servicio (Gmail, Outlook, etc.)
# 3. Crear una plantilla de email
# 4. Copiar las credenciales aquí
EMAILJS_SERVICE_ID=TU_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=TU_EMAILJS_TEMPLATE_ID
EMAILJS_PUBLIC_KEY=TU_EMAILJS_PUBLIC_KEY
EMAILJS_CANCELLATION_TEMPLATE_ID=TU_EMAILJS_CANCELLATION_TEMPLATE_ID

# --- FTP DEPLOY (Producción) ---
# Solo necesario si vas a hacer deploy a un servidor
FTP_HOST=tu_host_ftp
FTP_USER=tu_usuario_ftp
FTP_PASS=tu_password_ftp
FTP_PORT=22
FTP_REMOTE_PATH=/Bienestar/
FTP_SFTP=true
