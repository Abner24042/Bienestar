# ===========================================
# BIENIESTAR - Variables de entorno
# Copia este archivo como .env:
#   Windows cmd:  copy .env.example .env
#   Git Bash:     cp .env.example .env
# Luego llena los valores según las instrucciones de cada sección.
# ===========================================


# --- APLICACIÓN ---
# Cambia esto según dónde pusiste el proyecto en htdocs.
# Ejemplos:
#   http://localhost/Bienestar/public        ← si está en htdocs/Bienestar
#   http://localhost/proyectos/Bienestar/public  ← si está en subcarpeta
APP_ENV=development
APP_DEBUG=true
BASE_URL=http://localhost/Bienestar/public


# --- BASE DE DATOS ---
# Con XAMPP por defecto el usuario es root y no tiene contraseña.
DB_HOST=localhost
DB_NAME=sistema_usuarios
DB_USER=root
DB_PASS=


# --- GOOGLE OAUTH ---
# Pídele estas credenciales directamente al desarrollador (Abner),
# él te las manda por fuera del repo porque no se pueden subir a GitHub.
# Si quieres crear las tuyas propias:
#   1. Ve a https://console.cloud.google.com
#   2. Crea un proyecto → APIs y servicios → Credenciales
#   3. Crear credencial → ID de cliente OAuth 2.0 → Aplicación web
#   4. En "URIs de redireccionamiento autorizados" agrega:
#      http://localhost/Bienestar/public/auth/google/callback
#   5. Copia el Client ID y Client Secret aquí abajo
GOOGLE_CLIENT_ID=PEDIR_AL_DESARROLLADOR
GOOGLE_CLIENT_SECRET=PEDIR_AL_DESARROLLADOR
GOOGLE_REDIRECT_URI=http://localhost/Bienestar/public/auth/google/callback


# --- EMAIL (SMTP) ---
# Solo necesario si quieres que funcionen los correos de citas.
# Con Gmail: activa la verificación en 2 pasos y genera una
# "Contraseña de aplicación" en tu cuenta de Google.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion_gmail
MAIL_FROM=noreply@bieniestar.com
MAIL_FROM_NAME=BIENIESTAR


# --- GOOGLE CALENDAR API ---
# Mismas credenciales que Google OAuth (mismo proyecto de Google Cloud).
# Solo necesario si usas la funcionalidad de calendario en Citas.
GOOGLE_CALENDAR_CLIENT_ID=PEDIR_AL_DESARROLLADOR
GOOGLE_CALENDAR_CLIENT_SECRET=PEDIR_AL_DESARROLLADOR
GOOGLE_CALENDAR_API_KEY=PEDIR_AL_DESARROLLADOR
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost/Bienestar/public/pages/citas.php


# --- EMAILJS ---
# Solo necesario para el envío de correos de confirmación/cancelación de citas.
# Pídele las credenciales al desarrollador o crea una cuenta en emailjs.com.
EMAILJS_SERVICE_ID=PEDIR_AL_DESARROLLADOR
EMAILJS_TEMPLATE_ID=PEDIR_AL_DESARROLLADOR
EMAILJS_PUBLIC_KEY=PEDIR_AL_DESARROLLADOR
EMAILJS_CANCELLATION_TEMPLATE_ID=PEDIR_AL_DESARROLLADOR


# --- FTP DEPLOY ---
# Solo si vas a hacer deploy a un servidor de producción. No necesario en local.
FTP_HOST=tu_host_ftp
FTP_USER=tu_usuario_ftp
FTP_PASS=tu_password_ftp
FTP_PORT=22
FTP_REMOTE_PATH=/Bienestar/
FTP_SFTP=true
